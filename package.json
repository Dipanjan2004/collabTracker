{
  "name": "collabtrack",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "build": "npm run build --workspace=frontend",
    "start": "cd backend && uvicorn app.main:app --port 8000",
    "seed": "cd backend && python scripts/seed.py",
    "create-admin": "cd backend && python scripts/create_admin.py",
    "create-collaborator": "cd backend && python scripts/create_collaborator.py",
    "make-admin": "cd backend && python scripts/make_admin.py",
    "install:all": "npm install && cd backend && pip install -r requirements.txt"
  }
}